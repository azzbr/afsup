rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    // Check if user is logged in (anon or real)
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if user is a fully registered staff/admin (not anonymous)
    function isVerifiedUser() {
      return isAuthenticated() && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    // Get the user's role from their user document
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Head Admin / super_admin. Inherits every admin power (see CLAUDE.md §6
    // and PHASES.md Phase 2.6) plus principal-only capabilities: writing to
    // a super_admin's user doc and editing the admin tier's salary fields.
    function isSuperAdmin() {
      return isVerifiedUser() && getUserRole() == 'super_admin';
    }

    function isAdmin() {
      return isVerifiedUser() && (getUserRole() == 'admin' || getUserRole() == 'super_admin');
    }

    function isHR() {
      return isVerifiedUser() && getUserRole() == 'hr';
    }

    function isMaintenance() {
      return isVerifiedUser() && (getUserRole() == 'maintenance' || getUserRole() == 'admin' || getUserRole() == 'super_admin');
    }

    // Fields a user may NEVER set on their own profile (CLAUDE.md section 5:
    // salary, leave balances, sick days, joining date, employee number are
    // HR/admin-only; viewAll is the legacy admin back-door flag).
    function restrictedSelfFields() {
      return ['basicSalary', 'housingAllowance', 'transportAllowance',
              'phoneAllowance', 'annualLeaveBalance', 'sickDaysUsed',
              'leaveBalances', 'dateOfJoining', 'employeeNumber', 'viewAll'];
    }

    // Salary/leave fields that only a super_admin may edit when the target
    // doc belongs to an admin (matrix: "Edit salary of admin or super_admin"
    // is super_admin-only).
    function salaryTierFields() {
      return ['basicSalary', 'housingAllowance', 'transportAllowance',
              'phoneAllowance', 'annualLeaveBalance', 'sickDaysUsed',
              'leaveBalances'];
    }

    // --- Collection Rules ---

    // 1. Users Collection
    match /users/{userId} {
      // READ (Phase 2.9.1 — admin is a pure operations role):
      //   - own profile
      //   - super_admin sees everyone
      //   - plain admin sees staff + maintenance docs plus admin peers
      //     (matrix: "View admin profiles" is an admin grant; hr-role and
      //     super_admin profiles are off-limits; list queries must be
      //     role-scoped — see useUsers). isAdmin() includes super_admin,
      //     which is fine because isSuperAdmin() is checked first.
      //   - HR sees non-admin-tier (staff, maintenance, hr)
      //   - maintenance sees staff + maintenance
      //   - staff sees other staff
      allow read: if isAuthenticated() && (
        request.auth.uid == userId ||
        isSuperAdmin() ||
        (isAdmin() && resource.data.role in ['staff', 'maintenance', 'admin']) ||
        (isHR() && resource.data.role != 'admin' && resource.data.role != 'super_admin') ||
        (getUserRole() == 'maintenance' && ['staff', 'maintenance'].hasAny([resource.data.role])) ||
        (getUserRole() == 'staff' && resource.data.role == 'staff')
      );

      // CREATE:
      //   - Self-registration (legacy path): must start as 'pending', cannot self-elevate to admin or super_admin
      //   - Super-admin email seed: allowed to bootstrap the first admin
      //   - Invitation Cloud Function creates with status='invited' via admin SDK (bypasses rules)
      allow create: if isAuthenticated() && request.auth.uid == userId
                    && (
                       (request.resource.data.status == 'pending'
                        && request.resource.data.role != 'admin'
                        && request.resource.data.role != 'super_admin')
                       ||
                       (request.auth.token.email == 'admin@afs.edu.bh')
                    );

      // UPDATE — IMPORTANT INVARIANTS (Phase 2.9.1):
      //   - role and status can NEVER be changed via direct client write.
      //     Both go through the updateUserRole / updateUserStatus Cloud
      //     Functions, which write audit_log atomically.
      //   - Plain admin client-writes NOTHING on other users' docs — profile
      //     data is people data (hr/super_admin only); the staff/maintenance
      //     lifecycle goes through the Cloud Functions, which are scoped
      //     server-side in functions/src/permissions.ts.
      //   - super_admin can edit any doc, HR can edit non-admin-tier docs
      //     (salary, leave balance, etc.), and any user can edit their own
      //     non-restricted profile fields.
      allow update: if (
        // role + status are immutable from the client surface
        request.resource.data.role == resource.data.role
        && request.resource.data.status == resource.data.status
      ) && (
        // NEVER-self guard (CLAUDE.md section 5): salary/leave-balance fields
        // are HR-only and never self-editable. Applies to EVERY branch
        // below — without it an HR (or super_admin) actor passes their role
        // branch and the own-profile restrictedSelfFields() check is skipped.
        request.auth.uid != userId
        || !request.resource.data.diff(resource.data).affectedKeys().hasAny(salaryTierFields())
      ) && (
        isSuperAdmin()
        || (isHR() && resource.data.role != 'admin' && resource.data.role != 'super_admin')
        || (
          // Own-profile branch: never the HR-only fields.
          isAuthenticated() && request.auth.uid == userId
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(restrictedSelfFields())
        )
      );

      // DELETE — disallowed from the client.
      // deleteUser Cloud Function removes both the auth user and this doc;
      // direct client deletes would leave orphaned auth accounts that
      // prevent re-invite of the same email.
      allow delete: if false;
    }

    // 2. Maintenance Tickets
    match /maintenance_tickets/{ticketId} {
      // Any authenticated user (incl. anonymous kiosk reporters) may read
      // tickets — required by the submit form's duplicate-report guard and
      // the My Reports list; maintenance ticket content is low-sensitivity.
      // UI gating still follows the CLAUDE.md section 6 matrix.
      allow read: if isAuthenticated();

      // Anyone (including anonymous guests) can create a ticket.
      allow create: if isAuthenticated();

      // Updates:
      // Maintenance/Admins can update status, assign, add notes.
      // Regular users CANNOT update tickets once sent (prevents tampering).
      allow update: if isAdmin() || isMaintenance();

      // Only Admins can delete tickets.
      allow delete: if isAdmin();
    }

    // 3. Scheduled Tasks (Backend/Admin only)
    match /scheduled_tasks/{taskId} {
      allow read, write: if isAdmin();
    }

    // 4. Leave Requests Collection (Phase 2.9.1: leave is people data —
    // hr/super_admin only; plain admin is out entirely)
    match /leave_requests/{requestId} {
      // READ: Author can see own requests; HR and the Head Admin see all
      allow read: if isSuperAdmin() || isHR() ||
                  (isAuthenticated() && resource.data.userId == request.auth.uid);

      // CREATE: Authenticated users can create leave requests for themselves,
      // and every request starts pending.
      allow create: if isAuthenticated() &&
                    request.auth.uid == request.resource.data.userId &&
                    request.resource.data.status == 'pending';

      // UPDATE: HR/Head Admin may edit non-status fields only. Approve/reject
      // decisions go through the decideLeaveRequest Cloud Function (admin
      // SDK bypasses these rules), which debits balances atomically and
      // blocks deciding your own request.
      allow update: if (isSuperAdmin() || isHR()) &&
                    request.resource.data.status == resource.data.status;

      // DELETE: Head Admin only
      allow delete: if isSuperAdmin();
    }

    // 5. Invitations Collection (Phase 2 — invitation-based onboarding)
    //
    // Tokens here are unguessable (32 random bytes, hex-encoded) and short-
    // lived (7 days). All writes go through Cloud Functions running as admin
    // (which bypass these rules), so the client never writes here.
    //
    // The /accept-invite React page reads the invitation by its token to
    // show the right email/role on screen before submitting the password.
    // Anyone with the token (i.e. the legitimate invitee) can read; nobody
    // else can list the collection because token IDs are unguessable.
    match /invitations/{token} {
      allow read: if true;
      allow write: if false; // Cloud Functions only.
    }

    // 6. Audit Log (Phase 1/2 — append-only history)
    //
    // Written exclusively by Cloud Functions. super_admin reads everything;
    // HR reads only entries about non-admin-tier targets
    // (targetAdminTier == false, per the CLAUDE.md section 6 matrix).
    // Plain admin reads nothing (Phase 2.9.1 — the audit log is people
    // data). Pre-2026-06-11 entries lack the field and so remain
    // super_admin-only (safe default). No one may update or delete.
    match /audit_log/{entry} {
      allow read: if isSuperAdmin() ||
                  (isHR() && resource.data.targetAdminTier == false);
      allow write: if false; // Cloud Functions only.
    }

    // 7. Notifications (Phase 2 placeholder — used by Phase 4 too)
    //
    // Written by Cloud Functions. Each notification targets a specific uid
    // or a role broadcast key (e.g. "role:hr"). Users read their own + any
    // broadcasts matching their role. Only the Head Admin may read across
    // all targets (Phase 2.9.1: role:hr broadcasts and leave_decision
    // notifications carry people data — a plain admin must not be able to
    // query them; the role-broadcast branch already covers role:admin).
    match /notifications/{notification} {
      allow read: if isAuthenticated() && (
        resource.data.targetUid == request.auth.uid ||
        resource.data.targetUid == 'role:' + getUserRole() ||
        isSuperAdmin()
      );
      // Users may mark their own notifications as read by patching readAt.
      allow update: if isAuthenticated() &&
                    resource.data.targetUid == request.auth.uid &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readAt']);
      allow create, delete: if false; // Cloud Functions only.
    }

    // 8. School Settings (Phase 2.6 — singleton doc, id 'current')
    //
    // HR/admin dashboards read the current values; ONLY the
    // updateSchoolSettings Cloud Function (gated to super_admin) writes,
    // so every change is whitelist-validated and audit-logged.
    match /school_settings/{settingsId} {
      allow read: if isAdmin() || isHR();
      allow write: if false; // Cloud Functions only.
    }
  }
}
