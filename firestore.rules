rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    // Check if user is logged in (anon or real)
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if user is a fully registered staff/admin (not anonymous)
    function isVerifiedUser() {
      return isAuthenticated() && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    // Get the user's role from their user document
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Head Admin / super_admin. Inherits every admin power (see CLAUDE.md §6
    // and PHASES.md Phase 2.6). Until Phase 2.6 carves out super-admin-only
    // capabilities, super_admin and admin are functionally equal here.
    function isSuperAdmin() {
      return isVerifiedUser() && getUserRole() == 'super_admin';
    }

    function isAdmin() {
      return isVerifiedUser() && (getUserRole() == 'admin' || getUserRole() == 'super_admin');
    }

    function isMaintenance() {
      return isVerifiedUser() && (getUserRole() == 'maintenance' || getUserRole() == 'admin' || getUserRole() == 'super_admin');
    }

    // --- Collection Rules ---

    // 1. Users Collection
    match /users/{userId} {
      // READ:
      //   - own profile
      //   - admin sees everyone
      //   - HR sees non-admins
      //   - maintenance sees staff + maintenance
      //   - staff sees other staff
      allow read: if isAuthenticated() && (
        request.auth.uid == userId ||
        isAdmin() ||
        (getUserRole() == 'hr' && resource.data.role != 'admin' && resource.data.role != 'super_admin') ||
        (getUserRole() == 'maintenance' && ['staff', 'maintenance'].hasAny([resource.data.role])) ||
        (getUserRole() == 'staff' && resource.data.role == 'staff')
      );

      // CREATE:
      //   - Self-registration (legacy path): must start as 'pending', cannot self-elevate to admin or super_admin
      //   - Super-admin email seed: allowed to bootstrap the first admin
      //   - Invitation Cloud Function creates with status='invited' via admin SDK (bypasses rules)
      allow create: if isAuthenticated() && request.auth.uid == userId
                    && (
                       (request.resource.data.status == 'pending'
                        && request.resource.data.role != 'admin'
                        && request.resource.data.role != 'super_admin')
                       ||
                       (request.auth.token.email == 'admin@afs.edu.bh')
                    );

      // UPDATE — IMPORTANT INVARIANTS:
      //   - role and status can NEVER be changed via direct client write.
      //     Both go through the updateUserRole / updateUserStatus Cloud
      //     Functions, which write audit_log atomically.
      //   - Subject to that, admin/super_admin can edit anyone, HR can edit
      //     non-admins (salary, leave balance, etc.), and any user can edit
      //     their own non-restricted profile fields.
      allow update: if (
        // role + status are immutable from the client surface
        request.resource.data.role == resource.data.role
        && request.resource.data.status == resource.data.status
      ) && (
        isAdmin()
        || (getUserRole() == 'hr' && resource.data.role != 'admin' && resource.data.role != 'super_admin')
        || (isAuthenticated() && request.auth.uid == userId)
      );

      // DELETE — disallowed from the client.
      // deleteUser Cloud Function removes both the auth user and this doc;
      // direct client deletes would leave orphaned auth accounts that
      // prevent re-invite of the same email.
      allow delete: if false;
    }

    // 2. Maintenance Tickets
    match /maintenance_tickets/{ticketId} {
      // Any authenticated user (incl. anonymous kiosk reporters) may read
      // tickets — required by the submit form's duplicate-report guard and
      // the My Reports list; maintenance ticket content is low-sensitivity.
      // UI gating still follows the CLAUDE.md section 6 matrix.
      allow read: if isAuthenticated();

      // Anyone (including anonymous guests) can create a ticket.
      allow create: if isAuthenticated();

      // Updates:
      // Maintenance/Admins can update status, assign, add notes.
      // Regular users CANNOT update tickets once sent (prevents tampering).
      allow update: if isAdmin() || isMaintenance();

      // Only Admins can delete tickets.
      allow delete: if isAdmin();
    }

    // 3. Scheduled Tasks (Backend/Admin only)
    match /scheduled_tasks/{taskId} {
      allow read, write: if isAdmin();
    }

    // 4. Leave Requests Collection
    match /leave_requests/{requestId} {
      // READ: Author can see own requests, Admins see all
      allow read: if isAdmin() ||
                  (isAuthenticated() && resource.data.userId == request.auth.uid);

      // CREATE: Authenticated users can create leave requests for themselves
      allow create: if isAuthenticated() &&
                    request.auth.uid == request.resource.data.userId;

      // UPDATE: Admins can update status. Authors CANNOT update requests once submitted.
      allow update: if isAdmin();

      // DELETE: Admins only
      allow delete: if isAdmin();
    }

    // 5. Invitations Collection (Phase 2 — invitation-based onboarding)
    //
    // Tokens here are unguessable (32 random bytes, hex-encoded) and short-
    // lived (7 days). All writes go through Cloud Functions running as admin
    // (which bypass these rules), so the client never writes here.
    //
    // The /accept-invite React page reads the invitation by its token to
    // show the right email/role on screen before submitting the password.
    // Anyone with the token (i.e. the legitimate invitee) can read; nobody
    // else can list the collection because token IDs are unguessable.
    match /invitations/{token} {
      allow read: if true;
      allow write: if false; // Cloud Functions only.
    }

    // 6. Audit Log (Phase 1/2 — append-only history)
    //
    // Written exclusively by Cloud Functions. HR and admins may read for
    // forensic review. No one may update or delete.
    match /audit_log/{entry} {
      allow read: if isAdmin() || (isVerifiedUser() && getUserRole() == 'hr');
      allow write: if false; // Cloud Functions only.
    }

    // 7. Notifications (Phase 2 placeholder — used by Phase 4 too)
    //
    // Written by Cloud Functions. Each notification targets a specific uid
    // or a role broadcast key (e.g. "role:hr"). Users read their own + any
    // broadcasts matching their role.
    match /notifications/{notification} {
      allow read: if isAuthenticated() && (
        resource.data.targetUid == request.auth.uid ||
        resource.data.targetUid == 'role:' + getUserRole() ||
        isAdmin()
      );
      // Users may mark their own notifications as read by patching readAt.
      allow update: if isAuthenticated() &&
                    resource.data.targetUid == request.auth.uid &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readAt']);
      allow create, delete: if false; // Cloud Functions only.
    }
  }
}
