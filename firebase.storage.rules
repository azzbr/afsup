rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Check if user is logged in
    function isAuth() { return request.auth != null; }

    // Role of the requesting user, read from their Firestore user doc.
    function callerRole() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role;
    }

    // Check if file is image OR pdf
    function isValidType() {
      return request.resource.contentType.matches('image/.*') ||
             request.resource.contentType == 'application/pdf';
    }

    // Limit size to 5MB
    function isSmallEnough() { return request.resource.size < 5 * 1024 * 1024; }

    // SIS workbook upload size guard (Head Admin import). Content-type is NOT
    // gated here: browsers report .xlsx inconsistently (often
    // application/x-zip-compressed, since .xlsx is a zip container), which
    // blocked legitimate uploads. The import Cloud Function is the real
    // validator — it parses the file and fails the batch if it isn't a workbook.
    function isWorkbookSize() { return request.resource.size < 15 * 1024 * 1024; }

    // MAINTENANCE IMAGES (Public read for staff)
    match /ticket-images/{fileName} {
      allow read: if isAuth();
      allow create: if isAuth() && isValidType() && isSmallEnough();
    }

    // --- HR DOCUMENTS (SECURE VAULT) ---
    // Structure: hr-documents/{userId}/{filename}
    //
    // Mirrors the role matrix in CLAUDE.md §6 (Phase 2.9.1): HR documents
    // are people data — only HR and the Head Admin can read AND write other
    // users' documents (so HR can attach a new hire's CV during onboarding,
    // etc.). Plain admin has no access. Regular users can only access their
    // own folder.
    match /hr-documents/{userId}/{fileName} {
      // READ
      allow read: if isAuth() && (
        request.auth.uid == userId ||
        callerRole() == 'super_admin' ||
        callerRole() == 'hr'
      );

      // WRITE — same matrix, plus the file must be a valid type + size.
      allow write: if isAuth() && (
        request.auth.uid == userId ||
        callerRole() == 'super_admin' ||
        callerRole() == 'hr'
      ) && isValidType() && isSmallEnough();
    }

    // --- STUDENT SYSTEM IMPORTS (Head Admin only) ---
    // Structure: sis-imports/{uid}/{filename}. The admin uploads a workbook here,
    // then calls importStudentWorkbook({storagePath}); the function reads it via
    // the Admin SDK and deletes it afterwards. super_admin only; clients never
    // read another user's uploads.
    match /sis-imports/{uid}/{fileName} {
      allow read: if isAuth() && request.auth.uid == uid && callerRole() == 'super_admin';
      allow create: if isAuth() && request.auth.uid == uid && callerRole() == 'super_admin'
                    && isWorkbookSize();
    }
  }
}
